### `src/controllers/voluntario.controller.js`

```js
const Voluntario = require('../models/Voluntario.model');

exports.getVoluntarios = async (req, res) => {
  try {
    const { estado, huerta } = req.query;
    const filtro = {};
    if (estado) filtro.estado = estado;
    if (huerta) filtro.huertas = huerta;

    const voluntarios = await Voluntario.find(filtro)
      .populate('huertas', 'nombre')
      .populate('usuario', 'nombre email')
      .sort({ nombre: 1 });

    res.json({ ok: true, total: voluntarios.length, voluntarios });
  } catch (error) {
    res.status(500).json({ ok: false, mensaje: error.message });
  }
};

exports.getVoluntario = async (req, res) => {
  try {
    const voluntario = await Voluntario.findById(req.params.id)
      .populate('huertas', 'nombre ubicacion')
      .populate('usuario', 'nombre email rol');
    if (!voluntario) return res.status(404).json({ ok: false, mensaje: 'Voluntario no encontrado' });
    res.json({ ok: true, voluntario });
  } catch (error) {
    res.status(500).json({ ok: false, mensaje: error.message });
  }
};

exports.crearVoluntario = async (req, res) => {
  try {
    const voluntario = await Voluntario.create(req.body);
    res.status(201).json({ ok: true, voluntario });
  } catch (error) {
    res.status(400).json({ ok: false, mensaje: error.message });
  }
};

exports.actualizarVoluntario = async (req, res) => {
  try {
    const voluntario = await Voluntario.findByIdAndUpdate(req.params.id, req.body, {
      new: true,
      runValidators: true,
    });
    if (!voluntario) return res.status(404).json({ ok: false, mensaje: 'Voluntario no encontrado' });
    res.json({ ok: true, voluntario });
  } catch (error) {
    res.status(400).json({ ok: false, mensaje: error.message });
  }
};

exports.eliminarVoluntario = async (req, res) => {
  try {
    const voluntario = await Voluntario.findByIdAndDelete(req.params.id);
    if (!voluntario) return res.status(404).json({ ok: false, mensaje: 'Voluntario no encontrado' });
    res.json({ ok: true, mensaje: 'Voluntario eliminado correctamente' });
  } catch (error) {
    res.status(500).json({ ok: false, mensaje: error.message });
  }
};

exports.registrarHoras = async (req, res) => {
  try {
    const { horas } = req.body;
    const voluntario = await Voluntario.findByIdAndUpdate(
      req.params.id,
      { $inc: { horasAcumuladas: horas } },
      { new: true }
    );
    if (!voluntario) return res.status(404).json({ ok: false, mensaje: 'Voluntario no encontrado' });
    res.json({ ok: true, voluntario });
  } catch (error) {
    res.status(400).json({ ok: false, mensaje: error.message });
  }
};
```

