## 5. CRUD Huertas

### Prompt

```
Actúa como senior backend developer en Node.js + Express + Mongoose.

Genera el CRUD completo para el recurso Huerta del sistema "Huertas Comunitarias".

--- ARCHIVO 1: huerta.controller.js ---
Funciones requeridas:

getHuertas — GET con filtros opcionales por query string (?estado=activa), paginación
(?page=1&limit=10), populate del campo responsable (nombre, email),
devolver { ok, total, pagina, huertas }.

getHuerta — GET por ID, populate responsable completo, manejar 404.

crearHuerta — POST, usar req.body directamente, devolver 201.

actualizarHuerta — PUT por ID, usar findByIdAndUpdate con
{ new: true, runValidators: true }, manejar 404.

eliminarHuerta — DELETE por ID con findByIdAndDelete, manejar 404.

Todas las funciones con try/catch. Formato de respuesta uniforme:
{ ok: true/false, mensaje?, huerta/huertas? }

--- ARCHIVO 2: huerta.routes.js ---
- Aplicar middleware "proteger" a todas las rutas con router.use()
- GET / y GET /:id: cualquier usuario autenticado
- POST / y PUT /:id: roles admin y docente
- DELETE /:id: solo admin
- Usar restringirA() del auth middleware
```

---

### `src/controllers/huerta.controller.js`

```js
const Huerta = require('../models/Huerta.model');

exports.getHuertas = async (req, res) => {
  try {
    const { estado, page = 1, limit = 10 } = req.query;
    const filtro = {};
    if (estado) filtro.estado = estado;

    const skip = (page - 1) * limit;
    const [huertas, total] = await Promise.all([
      Huerta.find(filtro)
        .populate('responsable', 'nombre email')
        .skip(skip)
        .limit(Number(limit))
        .sort({ createdAt: -1 }),
      Huerta.countDocuments(filtro),
    ]);

    res.json({ ok: true, total, pagina: Number(page), huertas });
  } catch (error) {
    res.status(500).json({ ok: false, mensaje: error.message });
  }
};

exports.getHuerta = async (req, res) => {
  try {
    const huerta = await Huerta.findById(req.params.id)
      .populate('responsable', 'nombre email rol');
    if (!huerta) return res.status(404).json({ ok: false, mensaje: 'Huerta no encontrada' });
    res.json({ ok: true, huerta });
  } catch (error) {
    res.status(500).json({ ok: false, mensaje: error.message });
  }
};

exports.crearHuerta = async (req, res) => {
  try {
    const huerta = await Huerta.create(req.body);
    res.status(201).json({ ok: true, huerta });
  } catch (error) {
    res.status(400).json({ ok: false, mensaje: error.message });
  }
};

exports.actualizarHuerta = async (req, res) => {
  try {
    const huerta = await Huerta.findByIdAndUpdate(req.params.id, req.body, {
      new: true,
      runValidators: true,
    });
    if (!huerta) return res.status(404).json({ ok: false, mensaje: 'Huerta no encontrada' });
    res.json({ ok: true, huerta });
  } catch (error) {
    res.status(400).json({ ok: false, mensaje: error.message });
  }
};

exports.eliminarHuerta = async (req, res) => {
  try {
    const huerta = await Huerta.findByIdAndDelete(req.params.id);
    if (!huerta) return res.status(404).json({ ok: false, mensaje: 'Huerta no encontrada' });
    res.json({ ok: true, mensaje: 'Huerta eliminada correctamente' });
  } catch (error) {
    res.status(500).json({ ok: false, mensaje: error.message });
  }
};
```

