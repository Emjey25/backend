## 6. CRUD Cultivos

### Prompt

```
Actúa como senior backend developer en Node.js + Express + Mongoose.

Genera el CRUD completo para el recurso Cultivo del sistema "Huertas Comunitarias".

--- ARCHIVO 1: cultivo.controller.js ---
Funciones requeridas:

getCultivos — GET con filtros opcionales: ?huerta=id&estado=crecimiento&tipo=hortaliza.
Populate de huerta (nombre, ubicacion). Devolver { ok, total, cultivos }.

getCultivo — GET por ID con populate de huerta.

crearCultivo — POST desde req.body, devolver 201.

actualizarCultivo — PUT por ID. Lógica especial: si req.body.estado === 'cosechada' y
no se envía fechaCosechaReal, asignarla automáticamente con new Date().
Usar findByIdAndUpdate con { new: true, runValidators: true }.

eliminarCultivo — DELETE por ID.

--- ARCHIVO 2: cultivo.routes.js ---
- router.use(proteger) para todas las rutas
- GET: cualquier rol autenticado
- POST, PUT: admin o docente
- DELETE: solo admin

Estados del ciclo de vida: semilla → germinacion → crecimiento → fruicion →
lista_cosechar → cosechada
```

---

### `src/controllers/cultivo.controller.js`

```js
const Cultivo = require('../models/Cultivo.model');

exports.getCultivos = async (req, res) => {
  try {
    const { huerta, estado, tipo } = req.query;
    const filtro = {};
    if (huerta) filtro.huerta = huerta;
    if (estado) filtro.estado = estado;
    if (tipo) filtro.tipo = tipo;

    const cultivos = await Cultivo.find(filtro)
      .populate('huerta', 'nombre ubicacion')
      .sort({ createdAt: -1 });

    res.json({ ok: true, total: cultivos.length, cultivos });
  } catch (error) {
    res.status(500).json({ ok: false, mensaje: error.message });
  }
};

exports.getCultivo = async (req, res) => {
  try {
    const cultivo = await Cultivo.findById(req.params.id).populate('huerta', 'nombre ubicacion');
    if (!cultivo) return res.status(404).json({ ok: false, mensaje: 'Cultivo no encontrado' });
    res.json({ ok: true, cultivo });
  } catch (error) {
    res.status(500).json({ ok: false, mensaje: error.message });
  }
};

exports.crearCultivo = async (req, res) => {
  try {
    const cultivo = await Cultivo.create(req.body);
    res.status(201).json({ ok: true, cultivo });
  } catch (error) {
    res.status(400).json({ ok: false, mensaje: error.message });
  }
};

exports.actualizarCultivo = async (req, res) => {
  try {
    if (req.body.estado === 'cosechada' && !req.body.fechaCosechaReal) {
      req.body.fechaCosechaReal = new Date();
    }
    const cultivo = await Cultivo.findByIdAndUpdate(req.params.id, req.body, {
      new: true,
      runValidators: true,
    });
    if (!cultivo) return res.status(404).json({ ok: false, mensaje: 'Cultivo no encontrado' });
    res.json({ ok: true, cultivo });
  } catch (error) {
    res.status(400).json({ ok: false, mensaje: error.message });
  }
};

exports.eliminarCultivo = async (req, res) => {
  try {
    const cultivo = await Cultivo.findByIdAndDelete(req.params.id);
    if (!cultivo) return res.status(404).json({ ok: false, mensaje: 'Cultivo no encontrado' });
    res.json({ ok: true, mensaje: 'Cultivo eliminado correctamente' });
  } catch (error) {
    res.status(500).json({ ok: false, mensaje: error.message });
  }
};
```

