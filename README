## 10. Reportes y Dashboard

### Prompt

```
Actúa como senior backend developer en Node.js + Express + Mongoose con experiencia
en aggregation pipelines.

Genera el módulo de reportes para el sistema "Huertas Comunitarias". Este módulo
alimenta el "Dashboard Principal: Gestión ODS 2" del frontend.

--- ARCHIVO 1: reporte.controller.js ---
Funciones requeridas:

getDashboard — GET que retorna en una sola llamada con Promise.all():
  - totalHuertasActivas: countDocuments({ estado: 'activa' })
  - cosechasProximas: countDocuments({ estado: 'lista_cosechar' }) en Cultivo
  - voluntariosHoy: countDocuments({ estado: 'activo' }) en Voluntario
  - tareasPendientes y tareasEnProceso: conteos de Tarea
  - tareasPrioritarias: 5 tareas con estado pendiente o en_proceso, ordenadas por
    prioridad desc y fechaLimite asc, con populate de asignadoA
  - donacionesRecientes: últimas 5 donaciones con populate de huerta
  - cultivosEstado: aggregation que agrupa cultivos por estado
    ($group por _id: '$estado')
  - rendimientoPorMes: aggregation en Cultivo donde estado='cosechada', agrupar por
    año y mes de fechaCosechaReal, sumar cantidadCosechada, limit 6

getReporteCultivos — GET con filtros opcionales ?huerta&desde&hasta. Aggregation que
filtra cosechados en el rango de fechas y agrupa por tipo, sumando cantidadCosechada.

getReporteVoluntarios — GET top 10 voluntarios activos ordenados por horasAcumuladas
desc. Calcular totalHoras con reduce.

getReporteDonaciones — GET aggregation que agrupa donaciones por tipoDonacion,
cuenta total y suma valorEstimado.

--- ARCHIVO 2: reporte.routes.js ---
- Todas las rutas protegidas
- GET /dashboard
- GET /cultivos
- GET /voluntarios
- GET /donaciones
```

---

### `src/controllers/reporte.controller.js`

```js
const Huerta = require('../models/Huerta.model');
const Cultivo = require('../models/Cultivo.model');
const Voluntario = require('../models/Voluntario.model');
const Tarea = require('../models/Tarea.model');
const Donacion = require('../models/Donacion.model');

// GET /api/reportes/dashboard
exports.getDashboard = async (req, res) => {
  try {
    const [
      totalHuertasActivas,
      cosechasProximas,
      voluntariosHoy,
      tareasPendientes,
      tareasEnProceso,
      donacionesRecientes,
      cultivosEstado,
      rendimientoPorMes,
    ] = await Promise.all([
      Huerta.countDocuments({ estado: 'activa' }),
      Cultivo.countDocuments({ estado: 'lista_cosechar' }),
      Voluntario.countDocuments({ estado: 'activo' }),
      Tarea.countDocuments({ estado: 'pendiente' }),
      Tarea.countDocuments({ estado: 'en_proceso' }),
      Donacion.find().sort({ fechaDonacion: -1 }).limit(5).populate('huerta', 'nombre'),
      Cultivo.aggregate([{ $group: { _id: '$estado', total: { $sum: 1 } } }]),
      Cultivo.aggregate([
        { $match: { estado: 'cosechada', fechaCosechaReal: { $exists: true, $ne: null } } },
        {
          $group: {
            _id: { year: { $year: '$fechaCosechaReal' }, month: { $month: '$fechaCosechaReal' } },
            totalCosechado: { $sum: '$cantidadCosechada' },
            cantidad: { $sum: 1 },
          },
        },
        { $sort: { '_id.year': 1, '_id.month': 1 } },
        { $limit: 6 },
      ]),
    ]);

    const tareasPrioritarias = await Tarea.find({
      estado: { $in: ['pendiente', 'en_proceso'] },
    })
      .populate('asignadoA', 'nombre apellido')
      .sort({ prioridad: -1, fechaLimite: 1 })
      .limit(5);

    res.json({
      ok: true,
      resumenMensual: {
        totalHuertasActivas,
        cosechasProximas,
        voluntariosHoy,
        tareasPendientes,
        tareasEnProceso,
      },
      tareasPrioritarias,
      donacionesRecientes,
      cultivosEstado,
      rendimientoPorMes,
    });
  } catch (error) {
    res.status(500).json({ ok: false, mensaje: error.message });
  }
};

// GET /api/reportes/cultivos
exports.getReporteCultivos = async (req, res) => {
  try {
    const { huerta, desde, hasta } = req.query;
    const filtro = { estado: 'cosechada' };
    if (huerta) filtro.huerta = huerta;
    if (desde || hasta) {
      filtro.fechaCosechaReal = {};
      if (desde) filtro.fechaCosechaReal.$gte = new Date(desde);
      if (hasta) filtro.fechaCosechaReal.$lte = new Date(hasta);
    }
    const reporte = await Cultivo.aggregate([
      { $match: filtro },
      { $group: { _id: '$tipo', totalCosechado: { $sum: '$cantidadCosechada' }, cantidadCultivos: { $sum: 1 } } },
      { $sort: { totalCosechado: -1 } },
    ]);
    res.json({ ok: true, reporte });
  } catch (error) {
    res.status(500).json({ ok: false, mensaje: error.message });
  }
};

// GET /api/reportes/voluntarios
exports.getReporteVoluntarios = async (req, res) => {
  try {
    const voluntarios = await Voluntario.find({ estado: 'activo' })
      .populate('huertas', 'nombre')
      .sort({ horasAcumuladas: -1 })
      .limit(10);
    const totalHoras = voluntarios.reduce((acc, v) => acc + v.horasAcumuladas, 0);
    res.json({ ok: true, totalHoras, topVoluntarios: voluntarios });
  } catch (error) {
    res.status(500).json({ ok: false, mensaje: error.message });
  }
};

// GET /api/reportes/donaciones
exports.getReporteDonaciones = async (req, res) => {
  try {
    const resumen = await Donacion.aggregate([
      { $group: { _id: '$tipoDonacion', total: { $sum: 1 }, valorTotal: { $sum: '$valorEstimado' } } },
      { $sort: { total: -1 } },
    ]);
    res.json({ ok: true, resumen });
  } catch (error) {
    res.status(500).json({ ok: false, mensaje: error.message });
  }
};
```

### `src/routes/reporte.routes.js`

```js
const express = require('express');
const router = express.Router();
const {
  getDashboard, getReporteCultivos, getReporteVoluntarios, getReporteDonaciones,
} = require('../controllers/reporte.controller');
const { proteger } = require('../middleware/auth.middleware');

router.use(proteger);

router.get('/dashboard', getDashboard);
router.get('/cultivos', getReporteCultivos);
router.get('/voluntarios', getReporteVoluntarios);
router.get('/donaciones', getReporteDonaciones);

module.exports = router;
```

