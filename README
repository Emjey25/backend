## 8. CRUD Tareas

### Prompt

```
Actúa como senior backend developer en Node.js + Express + Mongoose.

Genera el CRUD completo para el recurso Tarea del sistema "Huertas Comunitarias".

--- ARCHIVO 1: tarea.controller.js ---
Funciones requeridas:

getTareas — GET con filtros: ?estado=pendiente&prioridad=alta&huerta=id&asignadoA=id&tipo=riego.
Populate de huerta (nombre), asignadoA (nombre, apellido), cultivo (nombre, emoji).
Ordenar por prioridad descendente y fechaLimite ascendente.

getTarea — GET por ID con populate completo.

crearTarea — POST, devolver 201.

actualizarTarea — PUT por ID. Si estado === 'completada' y no hay fechaCompletada en el body,
asignarla con new Date().

eliminarTarea — DELETE por ID.

cambiarEstado — PATCH rápido: recibe { estado } en el body, construye el objeto update
(agrega fechaCompletada si corresponde), usa findByIdAndUpdate. Este endpoint es para
voluntarios que cambian el estado de sus tareas asignadas.

--- ARCHIVO 2: tarea.routes.js ---
- Todas las rutas protegidas
- GET: cualquier autenticado
- POST, PUT: admin o docente
- DELETE: solo admin
- PATCH /:id/estado: cualquier autenticado (voluntarios pueden cambiar estado)
```

---

### `src/controllers/tarea.controller.js`

```js
const Tarea = require('../models/Tarea.model');

exports.getTareas = async (req, res) => {
  try {
    const { estado, prioridad, huerta, asignadoA, tipo } = req.query;
    const filtro = {};
    if (estado) filtro.estado = estado;
    if (prioridad) filtro.prioridad = prioridad;
    if (huerta) filtro.huerta = huerta;
    if (asignadoA) filtro.asignadoA = asignadoA;
    if (tipo) filtro.tipo = tipo;

    const tareas = await Tarea.find(filtro)
      .populate('huerta', 'nombre')
      .populate('asignadoA', 'nombre apellido')
      .populate('cultivo', 'nombre emoji')
      .sort({ prioridad: -1, fechaLimite: 1 });

    res.json({ ok: true, total: tareas.length, tareas });
  } catch (error) {
    res.status(500).json({ ok: false, mensaje: error.message });
  }
};

exports.getTarea = async (req, res) => {
  try {
    const tarea = await Tarea.findById(req.params.id)
      .populate('huerta', 'nombre ubicacion')
      .populate('asignadoA', 'nombre apellido email')
      .populate('cultivo', 'nombre emoji estado');
    if (!tarea) return res.status(404).json({ ok: false, mensaje: 'Tarea no encontrada' });
    res.json({ ok: true, tarea });
  } catch (error) {
    res.status(500).json({ ok: false, mensaje: error.message });
  }
};

exports.crearTarea = async (req, res) => {
  try {
    const tarea = await Tarea.create(req.body);
    res.status(201).json({ ok: true, tarea });
  } catch (error) {
    res.status(400).json({ ok: false, mensaje: error.message });
  }
};

exports.actualizarTarea = async (req, res) => {
  try {
    if (req.body.estado === 'completada' && !req.body.fechaCompletada) {
      req.body.fechaCompletada = new Date();
    }
    const tarea = await Tarea.findByIdAndUpdate(req.params.id, req.body, {
      new: true,
      runValidators: true,
    });
    if (!tarea) return res.status(404).json({ ok: false, mensaje: 'Tarea no encontrada' });
    res.json({ ok: true, tarea });
  } catch (error) {
    res.status(400).json({ ok: false, mensaje: error.message });
  }
};

exports.eliminarTarea = async (req, res) => {
  try {
    const tarea = await Tarea.findByIdAndDelete(req.params.id);
    if (!tarea) return res.status(404).json({ ok: false, mensaje: 'Tarea no encontrada' });
    res.json({ ok: true, mensaje: 'Tarea eliminada correctamente' });
  } catch (error) {
    res.status(500).json({ ok: false, mensaje: error.message });
  }
};

exports.cambiarEstado = async (req, res) => {
  try {
    const { estado } = req.body;
    const update = { estado };
    if (estado === 'completada') update.fechaCompletada = new Date();
    const tarea = await Tarea.findByIdAndUpdate(req.params.id, update, { new: true });
    if (!tarea) return res.status(404).json({ ok: false, mensaje: 'Tarea no encontrada' });
    res.json({ ok: true, tarea });
  } catch (error) {
    res.status(400).json({ ok: false, mensaje: error.message });
  }
};
```

### `src/routes/tarea.routes.js`

```js
const express = require('express');
const router = express.Router();
