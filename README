    fechaSiembra: { type: Date },
    fechaCosechaEstimada: { type: Date },
    fechaCosechaReal: { type: Date, default: null },
    cantidadSembrada: { type: Number, default: 0 },
    cantidadCosechada: { type: Number, default: 0 },
    unidad: {
      type: String,
      enum: ['kg', 'g', 'unidades', 'litros'],
      default: 'kg',
    },
    notas: { type: String },
    emoji: { type: String, default: '🌱' },
  },
  { timestamps: true }
);

module.exports = mongoose.model('Cultivo', cultivoSchema);
