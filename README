## 12. Seed de datos

> Ejecutar con `node seed.js` para poblar la base de datos con datos de prueba
> idénticos al dashboard de la imagen.

```js
require('dotenv').config();
const mongoose = require('mongoose');
const connectDB = require('./src/config/db');

const Usuario    = require('./src/models/Usuario.model');
const Huerta     = require('./src/models/Huerta.model');
const Cultivo    = require('./src/models/Cultivo.model');
const Voluntario = require('./src/models/Voluntario.model');
const Tarea      = require('./src/models/Tarea.model');
const Donacion   = require('./src/models/Donacion.model');

const seed = async () => {
  await connectDB();

  await Promise.all([
    Usuario.deleteMany(), Huerta.deleteMany(), Cultivo.deleteMany(),
    Voluntario.deleteMany(), Tarea.deleteMany(), Donacion.deleteMany(),
  ]);

  const docente = await Usuario.create({
    nombre: 'Mónica García', email: 'monica@huertas.com', password: '123456', rol: 'docente',
  });
  const admin = await Usuario.create({
    nombre: 'Admin Sistema', email: 'admin@huertas.com', password: '123456', rol: 'admin',
  });

  const h1 = await Huerta.create({
    nombre: 'Huerta Central Parque',
    ubicacion: { direccion: 'Parque Central, Calle 5 #10-20', lat: 6.2442, lng: -75.5812 },
    area: 200, responsable: docente._id, estado: 'activa',
  });
  const h2 = await Huerta.create({
    nombre: 'Huerta Comunitaria Sur',
    ubicacion: { direccion: 'Carrera 8 #15-30, Barrio Sur', lat: 6.2300, lng: -75.5900 },
    area: 150, responsable: docente._id, estado: 'activa',
  });

  await Cultivo.create([
    { nombre: 'Tomate Cherry', tipo: 'fruta', huerta: h1._id, estado: 'fruicion',
      fechaSiembra: new Date('2025-02-01'), cantidadSembrada: 50, unidad: 'unidades', emoji: '🍅' },
    { nombre: 'Zanahoria', tipo: 'hortaliza', huerta: h1._id, estado: 'crecimiento',
      fechaSiembra: new Date('2025-03-01'), cantidadSembrada: 2, unidad: 'kg', emoji: '🥕' },
    { nombre: 'Acelga', tipo: 'hortaliza', huerta: h2._id, estado: 'lista_cosechar',
      fechaSiembra: new Date('2025-01-15'), cantidadSembrada: 3, unidad: 'kg', emoji: '🥬' },
  ]);

  const v1 = await Voluntario.create({
    nombre: 'Ana', apellido: 'Rodríguez', email: 'ana@email.com',
    huertas: [h1._id], disponibilidad: ['lunes', 'miercoles'], horasAcumuladas: 24,
  });
  const v2 = await Voluntario.create({
    nombre: 'Juan', apellido: 'Pérez', email: 'juan@email.com',
    huertas: [h2._id], disponibilidad: ['martes', 'jueves'], horasAcumuladas: 16,
  });

  await Tarea.create([
    { titulo: 'Riego Diario', huerta: h1._id, asignadoA: v1._id,
      tipo: 'riego', prioridad: 'alta', estado: 'pendiente', fechaLimite: new Date() },
    { titulo: 'Siembra Lechuga', huerta: h2._id, asignadoA: v2._id,
      tipo: 'siembra', prioridad: 'media', estado: 'en_proceso',
      fechaLimite: new Date('2025-05-14') },
  ]);

  await Donacion.create([
    { donante: { nombre: 'Empresa X', tipo: 'empresa' }, huerta: h1._id,
      tipoDonacion: 'semillas', descripcion: 'Semillas de Maíz',
      cantidad: 10, unidad: 'kg', valorEstimado: 50000, estado: 'recibida', emoji: '🌽',
      fechaDonacion: new Date(Date.now() - 2 * 24 * 60 * 60 * 1000) },
  ]);

  console.log('\n✅ Seed completado');
  console.log('   Docente: monica@huertas.com / 123456');
  console.log('   Admin:   admin@huertas.com  / 123456\n');

  await mongoose.disconnect();
  process.exit(0);
};

seed().catch((err) => { console.error('❌ Error:', err); process.exit(1); });
```

