  getTareas, getTarea, crearTarea, actualizarTarea, eliminarTarea, cambiarEstado,
} = require('../controllers/tarea.controller');
const { proteger, restringirA } = require('../middleware/auth.middleware');

router.use(proteger);

router.get('/', getTareas);
router.get('/:id', getTarea);
router.post('/', restringirA('admin', 'docente'), crearTarea);
router.put('/:id', restringirA('admin', 'docente'), actualizarTarea);
router.delete('/:id', restringirA('admin'), eliminarTarea);
router.patch('/:id/estado', cambiarEstado);

module.exports = router;
```

